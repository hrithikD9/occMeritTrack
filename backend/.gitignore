# ============================================
# Backend - Git Ignore Configuration
# ============================================

# ============================================
# SECURITY - Environment Variables & Secrets
# ============================================
# ⚠️ CRITICAL: Never commit these files!
.env
.env.*
!.env.example
*.pem
*.key
*.cert
config/keys.js
secrets/

# ============================================
# Dependencies
# ============================================
node_modules/
jspm_packages/

# ============================================
# Logs
# ============================================
logs/
*.log
npm-debug.log*
yarn-debug.log*

# ============================================
# Database Files
# ============================================
*.sqlite
*.sqlite3
*.db

# ============================================
# Operating System Files
# ============================================
.DS_Store
Thumbs.db

# ============================================
# Temporary & Cache Files
# ============================================
*.tmp
*.temp
.cache/

# ============================================
# Testing & Coverage
# ============================================
coverage/
.nyc_output/
