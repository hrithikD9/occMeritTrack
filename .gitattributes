# ============================================
# OCC MeritTrack - Git Attributes
# ============================================
# This file defines how Git should handle line endings
# and perform merges for different file types

# ============================================
# Auto detect text files and normalize line endings
# ============================================
* text=auto

# ============================================
# Source Code
# ============================================
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# ============================================
# Configuration Files
# ============================================
.gitignore text eol=lf
.gitattributes text eol=lf
.editorconfig text eol=lf
.env.example text eol=lf

# ============================================
# Shell Scripts (Unix line endings)
# ============================================
*.sh text eol=lf
*.bash text eol=lf

# ============================================
# Windows Scripts
# ============================================
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# ============================================
# Documentation
# ============================================
*.txt text eol=lf
*.markdown text eol=lf
LICENSE text eol=lf
README text eol=lf

# ============================================
# Binary Files (do not attempt to modify)
# ============================================
# Images
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.ico binary
*.svg binary
*.webp binary

# Fonts
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary

# Archives
*.zip binary
*.tar binary
*.gz binary
*.7z binary
*.rar binary

# Video/Audio
*.mp4 binary
*.mov binary
*.avi binary
*.mp3 binary
*.wav binary

# ============================================
# Merge Strategies
# ============================================
# Avoid merge conflicts in lock files
package-lock.json merge=ours
yarn.lock merge=ours
pnpm-lock.yaml merge=ours

# Don't merge generated files
dist/** -merge
build/** -merge
coverage/** -merge

# ============================================
# Export Ignore (files not included in archives)
# ============================================
.gitattributes export-ignore
.gitignore export-ignore
.env.example export-ignore
*.test.js export-ignore
*.spec.js export-ignore
