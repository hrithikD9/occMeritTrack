# ============================================
# OCC MeritTrack Backend - Environment Variables
# ============================================
# ⚠️ IMPORTANT: Copy this file to .env and update with your actual values
# ⚠️ NEVER commit the actual .env file to version control!

# ============================================
# Server Configuration
# ============================================
PORT=5000
NODE_ENV=development

# ============================================
# Database Configuration
# ============================================
# MongoDB Atlas connection string (replace with your actual connection string)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/occmerittrack?retryWrites=true&w=majority

# ============================================
# JWT Authentication
# ============================================
# Generate a secure JWT secret using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=30d

# ============================================
# Teacher Authentication
# ============================================
# Change this passkey to something secure for production
TEACHER_PASSKEY=OCC2026
